{
  "manifest_version": 3,
  "name": "b-ark",
  "version": "0.1.0",
  "description": "Back up your Blipfoto journal.",
  "key": "TODO_REPLACE_AFTER_FIRST_LOAD",
  "permissions": ["storage", "webRequest", "webNavigation", "tabs"],
  "host_permissions": [
    "https://api.blipfoto.com/*",
    "https://*.cloudfront.net/*",
    "https://*.blipfoto.com/*"
  ],
  "background": {
    "service_worker": "src/sw.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "src/index.html",
    "default_title": "b-ark"
  }
}
