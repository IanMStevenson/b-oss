{
  "manifest_version": 3,
  "name": "b-ark-chrome",
  "version": "0.1.0",
  "description": "Back up your Blipfoto journal.",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "key": "",
  "permissions": ["storage", "webRequest", "webNavigation", "tabs"],
  "host_permissions": [
    "https://api.blipfoto.com/*",
    "https://*.cloudfront.net/*",
    "https://*.blipfoto.com/*"
  ],
  "background": {
    "service_worker": "src/sw.ts",
    "type": "module"
  },
  "action": {
    "default_title": "b-ark-chrome",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.blipfoto.com/*"],
      "js": ["src/chip-entry.ts"],
      "run_at": "document_end"
    }
  ]
}
