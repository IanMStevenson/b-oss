{
  "manifest_version": 3,
  "name": "b-ark",
  "version": "0.1.0",
  "description": "Back up your Blipfoto journal.",
  "key": "",
  "permissions": ["storage", "webRequest", "webNavigation", "tabs"],
  "host_permissions": [
    "https://api.blipfoto.com/*",
    "https://*.cloudfront.net/*",
    "https://*.blipfoto.com/*"
  ],
  "background": {
    "service_worker": "src/sw.ts",
    "type": "module"
  },
  "action": {
    "default_title": "b-ark"
  },
  "content_scripts": [
    {
      "matches": ["https://*.blipfoto.com/*"],
      "js": ["src/chip-entry.ts"],
      "run_at": "document_end"
    }
  ]
}
