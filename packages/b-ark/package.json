{
  "name": "b-ark",
  "version": "1.0.0",
  "private": true,
  "description": "b-ark Blipfoto journal backup for desktop",
  "author": {
    "name": "Ian Stevenson",
    "email": "Ian.Stevenson@cyclops-online.co.uk"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "electron-vite typecheck",
    "release": "electron-builder --publish always",
    "pack": "electron-vite build && electron-builder --dir",
    "predist": "npm run build --workspace=packages/b-view",
    "dist": "electron-vite build && electron-builder",
    "dist:win": "electron-vite build && electron-builder --win",
    "test": "vitest run"
  },
  "dependencies": {
    "@b-oss/b-ark-ui-electron": "*",
    "@b-oss/backup-engine": "*",
    "@b-oss/b-api": "*",
    "@b-oss/b-view": "*",
    "electron-log": "^5.0.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.0.0",
    "lucide-react": "^1.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "serve-handler": "^6.1.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/serve-handler": "^6.1.4",
    "electron": "^42.3.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.0"
  }
}
