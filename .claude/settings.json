{
  "permissions": {
    "allow": [
      "Bash(npm run typecheck)",
      "Bash(npm run typecheck *)",
      "Bash(npm run lint)",
      "Bash(npm run lint *)",
      "Bash(Get-ChildItem *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run typecheck 2>&1 | tail -30"
          }
        ]
      }
    ]
  }
}
