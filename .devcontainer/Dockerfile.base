FROM node:22-bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    unzip \
  && rm -rf /var/lib/apt/lists/*

# Install Claude Code globally
RUN npm install -g @anthropic-ai/claude-code

# Allow the node user to work in /workspaces without dubious-ownership errors
RUN git config --system --add safe.directory /workspaces/b-oss

# Pre-install Claude Code VS Code extension (linux-x64 platform-specific VSIX).
# The gallery API returns versions for multiple platforms; versions[0] is often macOS.
# We filter explicitly for linux-x64 to get the ELF binary, not the Mach-O one.
RUN curl -sfL \
      -X POST \
      -H "Content-Type: application/json" \
      -H "Accept: application/json;api-version=6.1-preview.1" \
      "https://marketplace.visualstudio.com/_apis/public/gallery/extensionquery" \
      -d '{"filters":[{"criteria":[{"filterType":7,"value":"anthropic.claude-code"}]}],"flags":3}' \
      > /tmp/gallery.json \
  && VSIX_URL=$(node -p " \
      const d=JSON.parse(require('fs').readFileSync('/tmp/gallery.json','utf8')); \
      const v=d.results[0].extensions[0].versions.find(v=>v.targetPlatform==='linux-x64'); \
      v.files.find(f=>f.assetType==='Microsoft.VisualStudio.Services.VSIXPackage').source") \
  && curl -fsSL "$VSIX_URL" -o /tmp/claude-code.vsix \
  && unzip -q /tmp/claude-code.vsix -d /tmp/claude-unpack \
  && EXT_VERSION=$(node -p "require('/tmp/claude-unpack/extension/package.json').version") \
  && mkdir -p /home/node/.vscode-server/extensions \
  && mv /tmp/claude-unpack/extension "/home/node/.vscode-server/extensions/anthropic.claude-code-${EXT_VERSION}" \
  && chown -R node:node /home/node/.vscode-server \
  && rm -rf /tmp/claude-code.vsix /tmp/claude-unpack /tmp/gallery.json

# Create .claude directory owned by node so Docker initialises the named volume
# with correct ownership when it is first mounted on an empty volume
RUN mkdir -p /home/node/.claude && chown node:node /home/node/.claude

USER node
WORKDIR /workspaces/b-oss
