# Blipfoto developer app credentials
# Register your app(s) at https://www.blipfoto.com/developer/apps

# --- Desktop b-ark (Electron) ---
# Register as "distributed app" type with redirect URI: b-ark://oauth/callback
# Must be prefixed MAIN_VITE_ so electron-vite exposes it to the main process via import.meta.env
MAIN_VITE_BLIPFOTO_CLIENT_ID=

# --- b-ark-chrome (browser extension) ---
# Register a SEPARATE "distributed app" with redirect URI: bark-chrome://oauth/callback
# (a dedicated scheme so an installed desktop b-ark can't intercept the redirect).
# Prefixed VITE_ so vite exposes it to the extension at build time. Without this,
# the "Sign in to Blipfoto" button silently does nothing (empty client_id).
# Read from the repo root (vite.config sets envDir to the repo root).
VITE_CHROME_CLIENT_ID=
